NODE_ENV=development
LOG_LEVEL=info
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vcloudrunner
DOCKER_SOCKET_PATH=/var/run/docker.sock
WORK_DIR=.tmp/deployments
PLATFORM_DOMAIN=platform.local
CADDY_ADMIN_URL=http://localhost:2019
DEPLOYMENT_DEFAULT_CONTAINER_PORT=3000
DEPLOYMENT_DEFAULT_MEMORY_MB=512
DEPLOYMENT_DEFAULT_CPU_MILLICORES=500
DEPLOYMENT_LOG_RETENTION_DAYS=14
DEPLOYMENT_LOG_MAX_ROWS_PER_DEPLOYMENT=2000
DEPLOYMENT_LOG_PRUNE_INTERVAL_MS=300000
DEPLOYMENT_LOG_ARCHIVE_DIR=.tmp/log-archives
DEPLOYMENT_LOG_ARCHIVE_INTERVAL_MS=3600000
DEPLOYMENT_LOG_ARCHIVE_MIN_AGE_DAYS=1
DEPLOYMENT_LOG_ARCHIVE_UPLOAD_PROVIDER=http
DEPLOYMENT_LOG_ARCHIVE_UPLOAD_BASE_URL=
DEPLOYMENT_LOG_ARCHIVE_UPLOAD_AUTH_TOKEN=
DEPLOYMENT_LOG_ARCHIVE_UPLOAD_INTERVAL_MS=600000
DEPLOYMENT_LOG_ARCHIVE_UPLOAD_TIMEOUT_MS=30000
DEPLOYMENT_LOG_ARCHIVE_UPLOAD_MAX_ATTEMPTS=3
DEPLOYMENT_LOG_ARCHIVE_UPLOAD_BACKOFF_BASE_MS=1000
DEPLOYMENT_LOG_ARCHIVE_UPLOAD_BACKOFF_MAX_MS=30000
DEPLOYMENT_LOG_ARCHIVE_S3_BUCKET=
DEPLOYMENT_LOG_ARCHIVE_S3_PREFIX=archives/deployments
DEPLOYMENT_LOG_ARCHIVE_S3_REGION=us-east-1
DEPLOYMENT_LOG_ARCHIVE_S3_ACCESS_KEY_ID=
DEPLOYMENT_LOG_ARCHIVE_S3_SECRET_ACCESS_KEY=
DEPLOYMENT_LOG_ARCHIVE_S3_SESSION_TOKEN=
DEPLOYMENT_LOG_ARCHIVE_GCS_BUCKET=
DEPLOYMENT_LOG_ARCHIVE_GCS_PREFIX=archives/deployments
DEPLOYMENT_LOG_ARCHIVE_GCS_ACCESS_TOKEN=
DEPLOYMENT_LOG_ARCHIVE_GCS_SERVICE_ACCOUNT_EMAIL=
DEPLOYMENT_LOG_ARCHIVE_GCS_PRIVATE_KEY=
DEPLOYMENT_LOG_ARCHIVE_AZURE_CONTAINER=
DEPLOYMENT_LOG_ARCHIVE_AZURE_PREFIX=archives/deployments
DEPLOYMENT_LOG_ARCHIVE_AZURE_ACCOUNT_NAME=
DEPLOYMENT_LOG_ARCHIVE_AZURE_ACCOUNT_KEY=
DEPLOYMENT_LOG_ARCHIVE_DELETE_LOCAL_AFTER_UPLOAD=false
DEPLOYMENT_LOG_ARCHIVE_CLEANUP_INTERVAL_MS=3600000
DEPLOYMENT_LOG_ARCHIVE_LOCAL_MAX_AGE_DAYS=30
DEPLOYMENT_LOG_ARCHIVE_MARKER_MAX_AGE_DAYS=90

