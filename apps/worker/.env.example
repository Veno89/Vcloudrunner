NODE_ENV=development
LOG_LEVEL=info
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vcloudrunner
DOCKER_SOCKET_PATH=/var/run/docker.sock
WORK_DIR=.tmp/deployments
PLATFORM_DOMAIN=platform.local
CADDY_ADMIN_URL=http://localhost:2019
DEPLOYMENT_DEFAULT_CONTAINER_PORT=3000
DEPLOYMENT_DEFAULT_MEMORY_MB=512
DEPLOYMENT_DEFAULT_CPU_MILLICORES=500
