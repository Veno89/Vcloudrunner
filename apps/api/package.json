{
  "name": "@vcloudrunner/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "npm --workspace @vcloudrunner/shared-types run build && tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "npm --workspace @vcloudrunner/shared-types run build && tsx --test \"src/**/*.test.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@vcloudrunner/shared-types": "0.1.0",
    "bullmq": "^5.16.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.57.0",
    "@opentelemetry/sdk-metrics": "^1.30.0",
    "@opentelemetry/auto-instrumentations-node": "^0.56.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@opentelemetry/resources": "^1.30.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "drizzle-kit": "^0.24.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
