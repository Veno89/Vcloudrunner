NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vcloudrunner
REDIS_URL=redis://localhost:6379
ENCRYPTION_KEY=change-this-with-a-32-byte-minimum-secret-key
DEPLOYMENT_DEFAULT_CONTAINER_PORT=3000
DEPLOYMENT_DEFAULT_MEMORY_MB=512
DEPLOYMENT_DEFAULT_CPU_MILLICORES=500

API_TOKENS_JSON=[{"token":"dev-admin-token","userId":"00000000-0000-0000-0000-000000000001","role":"admin"}]
# Optional bootstrap fallback. Prefer DB-managed tokens in api_tokens (revocation/expiry support).
