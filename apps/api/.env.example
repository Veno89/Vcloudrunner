NODE_ENV=development
HOST=0.0.0.0
PORT=4000
TRUST_PROXY=false
LOG_LEVEL=info
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vcloudrunner
REDIS_URL=redis://localhost:6379/0
ENCRYPTION_KEY=change-this-with-a-32-byte-minimum-secret-key
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=false
API_RATE_LIMIT_MAX=120
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_ALLOWLIST=127.0.0.1,::1
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_AUTH_TOKEN=
ALERT_MONITOR_INTERVAL_MS=30000
ALERT_COOLDOWN_MS=300000
ALERT_QUEUE_WAITING_THRESHOLD=50
ALERT_QUEUE_ACTIVE_THRESHOLD=20
ALERT_QUEUE_FAILED_THRESHOLD=10
DEPLOYMENT_DEFAULT_CONTAINER_PORT=3000
DEPLOYMENT_DEFAULT_MEMORY_MB=512
DEPLOYMENT_DEFAULT_CPU_MILLICORES=500
WORKER_HEARTBEAT_KEY=vcloudrunner:worker:heartbeat
WORKER_HEARTBEAT_STALE_MS=45000
ENABLE_DEV_AUTH=false

API_TOKENS_JSON=[{"token":"dev-admin-token","userId":"00000000-0000-0000-0000-000000000001","role":"admin"}]
# Optional bootstrap fallback. Prefer DB-managed tokens in api_tokens (revocation/expiry support).
# ENABLE_DEV_AUTH is a separate local-only bypass and should remain false unless you explicitly need it.
